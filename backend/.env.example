# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# JWT settings
JWT_PUBLIC_KEY="" # RS256 public key or JWK set URL
JWT_ALGORITHM=RS256

# Postgres for pgvector (optional)
DATABASE_URL=postgresql://rag_user:changeme@db:5432/rag_db

# Vector settings
VECTOR_PROVIDER=pgvector  # pgvector | in_memory

# App
APP_HOST=0.0.0.0
APP_PORT=8000
